# =============================================================================
# Flyx Self-Hosted Docker Environment
# Copy this to docker/.env and fill in your values
# =============================================================================

# TMDB API Key (REQUIRED - get free key at https://www.themoviedb.org/settings/api)
# Use the v3 API key (not the bearer token) for simplicity
NEXT_PUBLIC_TMDB_API_KEY=your_tmdb_v3_api_key_here
TMDB_API_KEY=your_tmdb_bearer_token_here

# Security secrets (change these to random strings)
JWT_SECRET=change-me-to-a-random-64-char-hex-string
SIGNING_SECRET=change-me-to-another-random-string
WATERMARK_SECRET=change-me-watermark-secret
ADMIN_SECRET=change-me-admin-secret

# VidSrc provider (set to true to enable - executes remote JS, use at own risk)
ENABLE_VIDSRC_PROVIDER=false

# RPI Proxy (optional - needed for some extractors like VidSrc, Flixer)
# If you have your own residential proxy, configure it here
# RPI_PROXY_URL=
# RPI_PROXY_KEY=

# DLHD Configuration (optional - for live TV)
# DLHD_PLAYER_DOMAIN=
# DLHD_CDN_DOMAIN=
# NEXT_PUBLIC_DLHD_API_KEY=

# Captcha solving (optional)
# CAPSOLVER_API_KEY=
