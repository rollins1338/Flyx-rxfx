# Flyx self-hosted Caddy config
# Serves flyx.local on port 80 (HTTP) with reverse proxy to Next.js + stream proxy

flyx.local {
	# Main app
	reverse_proxy flyx:3000

	# Proxy API routes that need the stream proxy
	handle /proxy/* {
		reverse_proxy proxy:8787
	}
}

# Stream proxy accessible directly at flyx.local:8787 is handled by Docker port mapping.
# This Caddy config provides the clean flyx.local (port 80) experience.

# If you want HTTPS with a self-signed cert for local use:
# flyx.local {
#   tls internal
#   reverse_proxy flyx:3000
# }
