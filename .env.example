# Cloudflare Worker URLs
NEXT_PUBLIC_CF_PROXY_URL=https://your-worker.workers.dev
NEXT_PUBLIC_CF_TV_PROXY_URL=https://your-tv-worker.workers.dev

# Use Cloudflare D1/KV bindings in local dev (requires wrangler)
# Set to 'true' to enable, omit or set to 'false' for local infra
USE_CLOUDFLARE_BACKEND=false

# DLHD Extractor Worker
NEXT_PUBLIC_DLHD_WORKER_URL=https://dlhd.vynx.workers.dev

# Security
SIGNING_SECRET=your-signing-secret-change-this-in-production
WATERMARK_SECRET=your-watermark-secret-change-this

# DLHD Configuration (NEVER commit actual values)
DLHD_PLAYER_DOMAIN=
DLHD_CDN_DOMAIN=

# RPI Proxy (optional - for bypassing CF IP blocks)
RPI_PROXY_URL=
RPI_PROXY_KEY=

# Captcha Solving (optional)
CAPSOLVER_API_KEY=

# Admin
ADMIN_SECRET=
