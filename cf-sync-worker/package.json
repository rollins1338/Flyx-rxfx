{
  "name": "flyx-sync-worker",
  "version": "1.0.0",
  "private": true,
  "description": "Cloudflare Worker for anonymous cross-device sync (watch progress, watchlist, settings)",
  "scripts": {
    "dev": "wrangler dev --local --persist-to .wrangler/state",
    "dev:remote": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:prod": "wrangler deploy --env production",
    "tail": "wrangler tail",
    "types": "wrangler types",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "fast-check": "^3.23.2",
    "typescript": "^5.3.3",
    "vitest": "^2.1.9",
    "wrangler": "^4.69.0"
  }
}
